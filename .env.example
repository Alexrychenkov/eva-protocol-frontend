# ============================================================================
# EVA frontend — environment variables
# Copy this file to `.env.local` and fill in. EVERY var here is OPTIONAL: the
# app boots and the public pages (Landing, Login, Register, Data, Docs) work
# with NONE of them set. Missing vars degrade specific features, they no longer
# crash the whole app (wallet init is wrapped, config fetch fails gracefully).
# Only VITE_* vars are exposed to the browser (Vite rule).
# ============================================================================

# ── Wallet (Connect Wallet button: Phantom, WalletConnect, etc.) ────────────
# Reown / WalletConnect project ID. Get yours at https://dashboard.reown.com
# If unset, a shared fallback ID is used (fine for local dev, set your own for prod).
VITE_REOWN_PROJECT_ID=cfc99e95c4e411baccd08624f2b47033

# ── Backend API ─────────────────────────────────────────────────────────────
# Base URL for the Go backend. Leave EMPTY for local dev — the Vite proxy
# (vite.config.ts) forwards /api to http://localhost:8080.
# In production set it to your deployed backend, e.g:
#   https://your-backend.yourdomain.com
# Used by: src/lib/httpClient.ts, src/lib/config.ts, src/pages/StrategyStudioPage.tsx
# (StrategyStudioPage also accepts the legacy VITE_API_BASE as a fallback.)
VITE_API_BASE_URL=

# ── Optional: Squid Router (cross-chain swap widget) ────────────────────────
# Integrator id sent as x-integrator-id. Defaults to 'oko-swap-widget-v1'.
# Only needed if you have your own SquidRouter integrator account.
VITE_SQUID_INTEGRATOR_ID=

# ── Optional: GMGN market data API key ──────────────────────────────────────
# Reserved for the GMGN data integration. Currently unused in src/ — safe to omit.
VITE_GMGN_API_KEY=
